PORT=5000

# Required on Railway / Render / etc. (no MongoDB on localhost there).
# Also accepts DATABASE_URL if your platform injects that name instead.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/popscore?appName=Pop

JWT_SECRET=your_super_secret_change_in_production

# Comma-separated frontend origins allowed by CORS (optional; *.railway.app / *.vercel.app allowed in prod).
# CLIENT_ORIGIN=https://popscore-production.up.railway.app,https://your-app.vercel.app
